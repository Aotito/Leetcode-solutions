class Solution(object):
    def isValid(self, s):
        """
        :type s: str
        :rtype: bool
        """
        stack = []

        for x in s:
            if x in "([{":
                stack.append(x)

            elif x in ")]}":
                if not stack:
                    return False

                out = stack.pop()

                if x == ')' and out != '(':
                    return False
                
                if x == '}' and out != '{':
                    return False
                if x == ']' and out != '[':
                    return False    
        return not stack
