class Solution(object):
    def twoSum(self, nums, target):
        """
        :type nums: List[int]
        :type target: int
        :rtype: List[int]
        """
        seen={}
        for i in range(len(nums)):
            x = nums[i]
            need = target - x
            if need in seen:
                return [i,seen[need]]
            seen[x] = i
